{
  "name": "todo-manager-react",
  "version": "1.0.0",
  "description": "WeekPlanner React + TypeScript Edition",
  "main": "electron/main.js",
  "homepage": ".",
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-scripts": "5.0.1",
    "typescript": "4.9.5",
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.11",
    "@types/node": "18.14.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:ui": "react-scripts start",
    "start:sync": "node md-sync-server.js",
    "build": "react-scripts build",
    "desktop": "npm run build && electron .",
    "dist:desktop": "npm run build && electron-builder --dir",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "extends": null,
    "appId": "com.weekplanner.desktop",
    "productName": "WeekPlanner",
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dir"
    },
    "win": {
      "target": "dir"
    },
    "linux": {
      "target": "dir"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
